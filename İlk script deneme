    part.Parent = workspace

    local sel = Instance.new("SelectionBox")
    sel.Color3 = Color3.fromRGB(255,178,0)
    sel.Adornee = part
    sel.Parent = part

    local numBB = Instance.new("BillboardGui")
    numBB.Size = UDim2.new(0,40,0,20)
    numBB.StudsOffset = Vector3.new(0,3,0)
