local function clearESP()
    for _,bb in pairs(espBillboards) do
        pcall(function() bb:Destroy() end)
    end
    espBillboards={}
end

local function createESP(plr)
    if espBillboards[plr] then return end
    if not plr.Character then return end
    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local bb = Instance.new("BillboardGui")
    bb.Name = "PhantomESP"
    bb.Size = UDim2.new(0,120,0,60)
    bb.StudsOffset = Vector3.new(0,3,0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = CFG.range
    bb.Adornee = hrp
    bb.Parent = hrp

    local nameL = Instance.new("TextLabel",bb)
    nameL.Size = UDim2.new(1,0,0.5,0)
    nameL.BackgroundTransparency = 1
    nameL.TextColor3 = Color3.fromRGB(255,50,50)
    nameL.TextSize = 14
    nameL.Font = Enum.Font.GothamBold
    nameL.Text = "["..plr.Name.."]"
    nameL.TextStrokeTransparency = 0
    nameL.TextStrokeColor3 = Color3.new(0,0,0)

    local infoL = Instance.new("TextLabel",bb)
    infoL.Size = UDim2.new(1,0,0.5,0)
    infoL.Position = UDim2.new(0,0,0.5,0)
    infoL.BackgroundTransparency = 1
    infoL.TextColor3 = Color3.fromRGB(255,200,0)
    infoL.TextSize = 11
    infoL.Font = Enum.Font.Code
    infoL.TextStrokeTransparency = 0
    infoL.TextStrokeColor3 = Color3.new(0,0,0)

    espBillboards[plr] = {bb=bb, info=infoL}

    -- Oyuncu ayrılırsa temizle
    plr.CharacterRemoving:Connect(function()
        if espBillboards[plr] then
            pcall(function() espBillboards[plr].bb:Destroy() end)
            espBillboards[plr]=nil
        end
    end)
end

local function updateESP()
    if not CFG.esp then clearESP(); return end
    for _,plr in ipairs(Plrs:GetPlayers()) do
        if plr~=me then
            createESP(plr)
            -- HP güncelle
            if espBillboards[plr] and plr.Character then
                local h=plr.Character:FindFirstChild("Humanoid")
                if h and espBillboards[plr].info then
                    local hp=math.floor((h.Health/math.max(h.MaxHealth,1))*100)
                    local dist=0
                    if root and plr.Character:FindFirstChild("HumanoidRootPart") then
                        dist=math.floor((root.Position-plr.Character.HumanoidRootPart.Position).Magnitude)
                    end
                    espBillboards[plr].info.Text = "HP:"..hp.."% | "..dist.."m"
                end
            end
        end
    end
end

