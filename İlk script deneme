    if fpt>=1 then fps=math.floor(fpc/fpt); fpc=0; fpt=0 end

    if not(hm and rt) then return end
    local pos=rt.Position
    if(pos-lastPos).Magnitude>.5 then lastMove=tick() end; lastPos=pos

    local el=tick()-lastMove; local iv=slI.v; local cd2=math.max(0,iv-el); local ratio=cd2/iv
    rainbow=tgRb.v; CFG.notifs=tgN.v; CFG.sounds=tgSo.v

    if rainbow then
        rhue=(rhue+dt*.08)%1
        local rc=Color3.fromHSV(rhue,.85,1)
        ms.Color=rc; cfi.BackgroundColor3=rc; lb.BackgroundColor3=rc
    end

    if CFG.on then
        cdn.Text=math.ceil(cd2).."s"; tw(cfi,{Size=UDim2.new(ratio,0,1,0)},.12)
        if not rainbow then cfi.BackgroundColor3=ratio>.5 and C().p1 or(ratio>.2 and C().yw or C().rd) end
        if el>5 then atx.Text="⚠ "..math.floor(el).."s AFK"; atx.TextColor3=C().yw; if el>longestAfk then longestAfk=el end
        else atx.Text="✓ Aktif"; atx.TextColor3=C().gn end
    else cdn.Text="—" end

    if hm then
        local hr=hm.Health/math.max(hm.MaxHealth,1); tw(hpf,{Size=UDim2.new(hr,0,1,0)},.2); hpv.Text=math.floor(hm.Health)
        local sr2=math.clamp(hm.WalkSpeed/40,0,1); tw(spf,{Size=UDim2.new(sr2,0,1,0)},.2); spv.Text=math.floor(hm.WalkSpeed)
        local jr=math.clamp(hm.JumpPower/100,0,1); tw(jpf,{Size=UDim2.new(jr,0,1,0)},.2); jpv.Text=math.floor(hm.JumpPower)
    end

    pcall(function() local pc=#P:GetPlayers(); svt.Text="Oyuncu: "..pc.." | "..game.Name:sub(1,20); ftx.Text="FPS: "..fps.." | Oyuncu: "..pc end)
    local ss=tick()-t0; gs.Text=fmt(ss); gj.Text=tostring(jumps); ga.Text=tostring(acts); gf.Text=tostring(afks)

    if wpTarget and hm and rt then
        if(rt.Position-wpTarget).Magnitude>4 then hm:MoveTo(wpTarget)
        else wpTarget=nil; nfy("Waypoint","Hedefe ulasildi!"); alog("Hedefe ulasildi!",C().gn) end
    end

    plt+=dt
    if plt>=2 then plt=0
        for _,plr in ipairs(P:GetPlayers()) do
            if plr~=pl and plc[plr.UserId] and plr.Character then
                local pr=plr.Character:FindFirstChild("HumanoidRootPart")
                if pr and rt then pcall(function() plc[plr.UserId].d.Text=math.floor((rt.Position-pr.Position).Magnitude).."m" end) end
            end
        end
    end

    st2+=dt
    if st2>=3 then st2=0
        local ss2=tick()-t0
        v1.Text=tostring(jumps); v2.Text=tostring(rots); v3.Text=tostring(walks)
        v4.Text=tostring(spins); v5.Text=tostring(acts); v6.Text=tostring(afks)
        v7.Text=fmt(ss2); v8.Text=math.floor(longestAfk).."s"
        v9.Text=ss2>0 and tostring(math.floor(acts/(ss2/60))) or "0"
        v10.Text=tostring(fps); v11.Text=tostring(#wps); pcall(function() v12.Text=tostring(#P:GetPlayers()) end)
    end

    lt2+=dt
    if lt2>=1.5 and tab=="log" then lt2=0; rlog() end

    if CFG.on and el>=iv then lastMove=tick(); task.spawn(fire) end
end)

