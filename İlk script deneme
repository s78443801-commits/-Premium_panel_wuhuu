    numL.TextSize = 14
    numL.Font = Enum.Font.GothamBold
    numL.Text = "WP"..wpCount
    numL.TextStrokeTransparency = 0

    table.insert(wpParts, part)
    lastWpPos = pos
    alog("WP"..wpCount.." eklendi",C().p1)
    nfy("WAYPOINT","WP"..wpCount.." eklendi",2)
end

local wpMarchIdx = 1
local wpMarching = false
local wpMarchConn = nil

local function startMarch()
    if #wps == 0 then alog("Waypoint yok!",C().red); return end
    CFG.march = true
    wpMarchIdx = 1
    wpMarching = true
    alog("MARCH BASLADI",C().grn)
    nfy("MARCH","Hareket başlıyor",2)

    if wpMarchConn then wpMarchConn:Disconnect() end

    wpMarchConn = Run.Heartbeat:Connect(function()
        if not CFG.march or not hum or not root then return end
        if wpMarchIdx > #wps then
            if CFG.autoWp then
                wpMarchIdx = 1
            else
                CFG.march = false
                wpMarching = false
                alog("MARCH TAMAMLANDI",C().p1)
                return
            end
        end

        local targetPos = wps[wpMarchIdx]
        local dist = (root.Position - targetPos).Magnitude

        if dist < CFG.followDst then
            wpMarchIdx = wpMarchIdx + 1
        else
            hum:MoveTo(targetPos)
        end
    end)
end

local function stopMarch()
    CFG.march = false
    wpMarching = false
    if wpMarchConn then wpMarchConn:Disconnect(); wpMarchConn=nil end
    if hum then hum:MoveTo(root.Position) end
    alog("MARCH DURDURULDU",C().sub)
end

local function clearWaypoints()
    stopMarch()
    wps={}; wpCount=0; lastWpPos=nil
    for _,p in ipairs(wpParts) do
        pcall(function() p:Destroy() end)
    end
    wpParts={}
    wpMarchIdx=1
    alog("WP TEMIZLENDI",C().sub)
end

-- ══════════════════════════════════════════════
--  TAKİP SİSTEMİ (DÜZELTİLDİ)
-- ══════════════════════════════════════════════
local followConn = nil

local function startFollow(plr)
    if followConn then followConn:Disconnect() end
    target = plr
    following = true
    alog("TAKİP: "..plr.Name,C().p1)
    nfy("TAKİP",plr.Name.." takip ediliyor",2)

    followConn = Run.Heartbeat:Connect(function()
        if not following or not target or not hum or not root then return end
        local tc = target.Character
        if not tc then return end
        local tr = tc:FindFirstChild("HumanoidRootPart")
        if not tr then return end
        local d = (root.Position - tr.Position).Magnitude
        if d > CFG.followDst then
            hum:MoveTo(tr.Position)
        end
    end)
end

local function stopFollow()
    following = false
    if followConn then followConn:Disconnect(); followConn=nil end
    target = nil
    alog("TAKİP DURDURULDU",C().sub)
end

