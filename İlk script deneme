--  YARDIMCI FONKSİYONLAR
-- ══════════════════════════════════════════════
local function tw(o,p,t)
    Tws:Create(o,TweenInfo.new(t or .2,Enum.EasingStyle.Quart),p):Play()
end

local function ts()
    local s=tick()-t0
    return string.format("[%02d:%02d]",math.floor(s/60),s%60)
end

local function nfy(ti,bo,dur)
    if CFG.notifs then
        pcall(function()
            SGui:SetCore("SendNotification",{Title=ti,Text=bo,Duration=dur or 3})
        end)
    end
end

local function alog(msg,col)
    table.insert(logLines,1,{t=ts().." "..msg, c=col or C().sub})
    if #logLines>30 then table.remove(logLines) end
end

local function getBearing(f,t2)
    if not f or not t2 then return "---" end
    local dx=t2.X-f.X; local dz=t2.Z-f.Z
    local a=math.deg(math.atan2(dx,dz))
    if a<0 then a=a+360 end
    local dirs={"N","NNE","NE","ENE","E","ESE","SE","SSE","S","SSW","SW","WSW","W","WNW","NW","NNW"}
    return dirs[math.floor(((a+11.25)/22.5)%16)+1]
end

local function scanNearby()
    nearbyPlrs={}
    if not root then return end
    for _,plr in ipairs(Plrs:GetPlayers()) do
        if plr~=me and plr.Character then
            local pr=plr.Character:FindFirstChild("HumanoidRootPart")
            if pr then
                local d=(root.Position-pr.Position).Magnitude
                if d<=CFG.range then
                    local hm2=plr.Character:FindFirstChild("Humanoid")
                    table.insert(nearbyPlrs,{
                        plr=plr, dist=math.floor(d), pos=pr.Position,
                        hp=hm2 and math.floor((hm2.Health/math.max(hm2.MaxHealth,1))*100) or 100,
                        threat=d<30 and "HIGH" or d<60 and "MED" or "LOW",
                    })
                end
            end
        end
    end
    table.sort(nearbyPlrs, function(a,b) return a.dist<b.dist end)
end

