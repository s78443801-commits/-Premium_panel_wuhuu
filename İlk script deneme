local function jump()
    if not hm then return end
    local s=hm:GetState()
    if s==Enum.HumanoidStateType.Running or s==Enum.HumanoidStateType.Landed
    or s==Enum.HumanoidStateType.RunningNoPhysics or s==Enum.HumanoidStateType.None then
        hm:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

