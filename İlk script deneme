local longestAfk=0
local function fire()
    CFG.on=CFG.on; local pool={}
    if tgJ.v then table.insert(pool,{n="Zipladi",c=C().gn,f=function() jump(); jumps+=1 end}) end
    if tgR.v then table.insert(pool,{n="Dondu",c=C().p1,f=function() if rt then rt.CFrame=rt.CFrame*CFrame.Angles(0,math.rad(45),0) end; rots+=1 end}) end
    if tgW.v then table.insert(pool,{n="Yurudu",c=C().p2,f=function() if rt and hm then hm:MoveTo(rt.Position+rt.CFrame.LookVector*4); task.delay(.7,function() if rt then hm:MoveTo(rt.Position) end end) end; walks+=1 end}) end
    if tgD.v then table.insert(pool,{n="Cift Zip",c=C().yw,f=function() jump(); task.wait(.25); jump(); jumps+=2 end}) end
    if tgS.v then table.insert(pool,{n="Spin",c=C().su,f=function() if rt then task.spawn(function() for _=1,8 do rt.CFrame=rt.CFrame*CFrame.Angles(0,math.rad(45),0); task.wait(.04) end end) end; spins+=1 end}) end
    if #pool==0 then return end
    local pk=pool[math.random(1,#pool)]; pcall(pk.f); acts+=1; afks+=1
    ltx.Text=pk.n; alog(pk.n,pk.c); if CFG.notifs and tgN.v then nfy("AntiAFK",pk.n) end
    tw(ms,{Color=C().p2,Thickness=3},.1); task.delay(.6,function() tw(ms,{Color=C().p1,Thickness=1.5,Transparency=.4},.4) end)
    tw(sd,{BackgroundColor3=C().p2},.1); task.delay(.5,function() if CFG.on then tw(sd,{BackgroundColor3=C().gn},.3) end end)
end

