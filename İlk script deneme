--  FLY SİSTEMİ (DÜZELTİLDİ)
-- ══════════════════════════════════════════════
local flySpeed = 40
local flyConn = nil

local function enableFly()
    if not root or flyActive then return end
    flyActive = true

    -- Eski bileşenleri temizle
    local oldBV = root:FindFirstChild("PhantomFlyBV")
    local oldBG = root:FindFirstChild("PhantomFlyBG")
    if oldBV then oldBV:Destroy() end
    if oldBG then oldBG:Destroy() end

    flyBV = Instance.new("BodyVelocity")
    flyBV.Name = "PhantomFlyBV"
    flyBV.Velocity = Vector3.zero
    flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    flyBV.Parent = root

    flyBG = Instance.new("BodyGyro")
    flyBG.Name = "PhantomFlyBG"
    flyBG.MaxTorque = Vector3.new(1e5,1e5,1e5)
    flyBG.D = 50
    flyBG.CFrame = root.CFrame
    flyBG.Parent = root

    if hum then
        hum.PlatformStand = true
    end

    flyConn = Run.RenderStepped:Connect(function()
        if not flyActive or not root then return end
        if not flyBV or not flyBV.Parent then return end

        local camCF = Cam.CFrame
        local dir = Vector3.zero

        -- WASD / Mobile için kamera yönü kullan
        local moveDir = Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) or UIS:IsKeyDown(Enum.KeyCode.E) then
            moveDir = moveDir + Vector3.new(0,1,0)
        end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) or UIS:IsKeyDown(Enum.KeyCode.Q) then
            moveDir = moveDir - Vector3.new(0,1,0)
        end

        -- Mobil: Humanoid MoveDirection kullan
        if isMobile and hum then
            local md = hum.MoveDirection
            if md.Magnitude > 0.1 then
                moveDir = md + Vector3.new(0, moveDir.Y, 0)
            end
        end

        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit
        end

        flyBV.Velocity = moveDir * flySpeed
        flyBG.CFrame = camCF
    end)

    nfy("FLY","Uçuş aktif",2)
    alog("FLY AKTIF",C().p2)
end

local function disableFly()
    flyActive = false
    if flyConn then flyConn:Disconnect(); flyConn=nil end
    if flyBV and flyBV.Parent then flyBV:Destroy() end
    if flyBG and flyBG.Parent then flyBG:Destroy() end
    flyBV=nil; flyBG=nil
    if hum then
        hum.PlatformStand = false
    end
    nfy("FLY","Uçuş devre dışı",2)
    alog("FLY KAPALI",C().sub)
end

