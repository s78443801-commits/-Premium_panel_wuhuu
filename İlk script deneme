local fpsSamples={}
local fpsSum=0
local lastFpsTick=tick()

-- ══════════════════════════════════════════════
--  ANA DÖNGÜ (RunService - DÜZELTİLDİ)
-- ══════════════════════════════════════════════
local scanTimer=0
local logTimer=0
local slY=0
local slDown=true
local fpsTimer=0

Run.Heartbeat:Connect(function(dt)
    if not CFG.enabled then return end

    scanTimer=scanTimer+dt
    logTimer=logTimer+dt
    fpsTimer=fpsTimer+dt
    blink=math.floor(tick()*2)%2==0

    -- FPS
    fpsSum=fpsSum+dt
    table.insert(fpsSamples,dt)
    if #fpsSamples>30 then
        fpsSum=fpsSum-table.remove(fpsSamples,1)
    end

    if fpsTimer>0.5 then
        fpsTimer=0
        local avgDt=fpsSum/math.max(#fpsSamples,1)
        local fps=math.floor(1/math.max(avgDt,0.001))
        if fpsL and fpsL.Parent then fpsL.Text="FPS: "..fps end

        -- Ping (yaklaşık)
        local ping=me:GetNetworkPing and math.floor(me:GetNetworkPing()*1000) or 0
        if pingL and pingL.Parent then pingL.Text="PING: "..ping.."ms" end
    end

    -- Scan
    if scanTimer>1 then
        scanTimer=0
        scanNearby()
        updateESP()
    end

    -- Log güncelle
    if logTimer>0.3 then
        logTimer=0
        for i,ll in ipairs(logLabels) do
            if logLines[i] then
                ll.Text=logLines[i].t
                ll.TextColor3=logLines[i].c
            else
                ll.Text=""
            end
        end
    end

    -- Auto Sprint
    if CFG.autoSprint and hum and hum.MoveDirection.Magnitude>0.1 then
        hum.WalkSpeed=CFG.speed
    end

    -- Koordinat HUD
    if root and coordXL and coordXL.Parent then
        local p=root.Position
        coordXL.Text=string.format("X: %.1f",p.X)
        coordYL.Text=string.format("Y: %.1f",p.Y)
        coordZL.Text=string.format("Z: %.1f",p.Z)
    end

    -- JJ Sayaç
    if jjRunning then
        jjTimer=jjTimer+dt
        if jjTimer>0.35 then
            jjTimer=0
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                jjCount=jjCount+1
                local pct=jjCount/math.max(jjTarget,1)
                jjCntLbl.Text=jjCount.." / "..jjTarget
                jjFill.Size=UDim2.new(pct,0,1,1)
                jjStLbl.Text="JUMP "..jjCount.."/"..jjTarget
            end
            if jjCount>=jjTarget then
                jjRunning=false
                jjStLbl.Text="TAMAMLANDI ✓"
                jjStLbl.TextColor3=C().p1
                alog("JJ TAMAMLANDI: "..jjTarget,C().p1)
                nfy("JJ","Tamamlandı!",2)
            end
        end
    end
end)

Run.RenderStepped:Connect(function(dt)
    if not CFG.enabled then return end

    -- Scanline animasyonu
    slY=slY+(slDown and 3 or -3)
    if slY>=PANEL_H then slDown=false elseif slY<=0 then slDown=true end
    if slF and slF.Parent then slF.Position=UDim2.new(0,0,0,slY) end

    -- Pusula
    if root then
        local camY=Cam.CFrame.LookVector
        local angle=math.deg(math.atan2(camY.X,camY.Z))
        if angle<0 then angle=angle+360 end
        local offset=-(angle/360)*(#compassDirs*36)
        for i,l in ipairs(compassLbls) do
            l.Position=UDim2.new(0,(i-1)*36+offset,0,0)
        end
    end

    -- RADAR güncelle (DÜZELTİLDİ)
    sweepAngle=sweepAngle+dt*90
    if sweepAngle>=360 then sweepAngle=sweepAngle-360 end
    if sweepLn and sweepLn.Parent then
        sweepLn.Rotation=sweepAngle
    end

    if root then
        for i,blip in ipairs(radarBlips) do
            local nd=nearbyPlrs[i]
            if nd then
                local rel=nd.pos-root.Position
                local camY2=Cam.CFrame.LookVector
                local camAngle=math.atan2(camY2.X,camY2.Z)
                local dx=rel.X*math.cos(-camAngle)-rel.Z*math.sin(-camAngle)
                local dz=rel.X*math.sin(-camAngle)+rel.Z*math.cos(-camAngle)
                local scale=RADAR_SIZE/2/CFG.range
                local rx=math.clamp(dx*scale,-RADAR_SIZE/2+4,RADAR_SIZE/2-4)
                local ry=math.clamp(dz*scale,-RADAR_SIZE/2+4,RADAR_SIZE/2-4)
                blip.Position=UDim2.new(0,RADAR_SIZE/2+rx-4,0,RADAR_SIZE/2+ry-4)
                blip.Visible=true
                -- Tehdit rengi
                local bc=nd.threat=="HIGH" and C().red or nd.threat=="MED" and Color3.fromRGB(255,165,0) or C().grn
                blip.BackgroundColor3=bc
                Instance.new("UICorner",blip).CornerRadius=UDim.new(1,0)

                -- Hedef kilitli yüzük
                if nd.plr==target then
                    lockRing.Position=UDim2.new(0,RADAR_SIZE/2+rx-11,0,RADAR_SIZE/2+ry-11)
                    lockRing.Visible=blink
                end
            else
                blip.Visible=false
            end
        end

        if target==nil then lockRing.Visible=false end
    end

    -- Target Lock güncelle
    if target and target.Character then
        local tr=target.Character:FindFirstChild("HumanoidRootPart")
        local th=target.Character:FindFirstChild("Humanoid")
        if tr and root then
            local d=(root.Position-tr.Position).Magnitude
            local hp2=th and math.floor((th.Health/math.max(th.MaxHealth,1))*100) or 0
            targetNameLbl.Text=target.Name
            targetNameLbl.TextColor3=C().p1
            tDist.Text=math.floor(d).."m"
            tBear.Text=getBearing(root.Position,tr.Position)
            tHp.Text=hp2.."%"
            tHp.TextColor3=hp2>60 and C().grn or hp2>30 and Color3.fromRGB(255,165,0) or C().red
            tThreat.Text=d<30 and "⚠ HIGH" or d<60 and "MED" or "LOW"
            tCoord.Text=string.format("%.0f,%.0f,%.0f",tr.Position.X,tr.Position.Y,tr.Position.Z)
            lockStatus.Text="● KİLİTLİ"
            lockStatus.TextColor3=blink and C().p1 or C().dim
            lbStr.Color=blink and C().p1 or C().dim
        end
    else
        targetNameLbl.Text="---"; targetNameLbl.TextColor3=C().dim
        tDist.Text="---"; tBear.Text="---"; tHp.Text="---"; tThreat.Text="---"; tCoord.Text="---"
        lockStatus.Text="TARANIO..."; lockStatus.TextColor3=C().sub
        lbStr.Color=C().p1; lbStr.Transparency=0.5
    end

    -- Danger overlay
    if #nearbyPlrs>0 and nearbyPlrs[1].threat=="HIGH" then
        dangerOv.Visible=true
        dangerT=dangerT+dt
        dangerOv.BackgroundTransparency=0.85+math.sin(dangerT*6)*0.1
    else
        dangerOv.Visible=false
        dangerT=0
    end

    -- Yakın oyuncu listesi (sol panel)
    for i,ll in ipairs(plrLabels) do
        local nd=nearbyPlrs[i]
        if nd then
            local icon=nd.threat=="HIGH" and "⚠" or nd.threat=="MED" and "◉" or "○"
            ll.Text=icon.." "..nd.plr.Name.." | "..nd.dist.."m | HP:"..nd.hp.."%"
            ll.TextColor3=nd.threat=="HIGH" and C().red or nd.threat=="MED" and Color3.fromRGB(255,165,0) or C().grn
        else
            ll.Text=""
        end
    end
end)

